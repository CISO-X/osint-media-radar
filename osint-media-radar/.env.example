# === OSINT Media Radar — API-ключи ===
# Все ключи ОПЦИОНАЛЬНЫ. Без них приложение работает через RSS + Google News.
# Каждый ключ добавляет дополнительные источники.

# GNews API — 100 запросов/день бесплатно
# Регистрация: https://gnews.io
GNEWS_API_KEY=

# NewsData.io — 200 кредитов/день бесплатно
# Регистрация: https://newsdata.io
NEWSDATA_API_KEY=

# Currents API — 600 запросов/день бесплатно
# Регистрация: https://currentsapi.services
CURRENTS_API_KEY=
